# ============================================
# VARIÁVEIS DE AMBIENTE — EXEMPLO
# ============================================
# 1. Copie este arquivo:       cp .env.example .env
# 2. Preencha os valores em .env
# 3. NUNCA commite .env (já está no .gitignore)
# 4. Se adicionar variável nova, atualize AQUI também (sem valor real)
# ============================================

# --- Claude / Anthropic (OBRIGATÓRIO) ---
# Chave do envelope do bootcamp. Limite individual de US$ 20.
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (OBRIGATÓRIO pro bootcamp) ---
# Project Settings > API no dashboard do Supabase
SUPABASE_URL=https://<seu-projeto>.supabase.co
SUPABASE_ANON_KEY=
# NÃO exponha a service role key no frontend — só use em backend
# SUPABASE_SERVICE_ROLE_KEY=

# --- Vercel (opcional — normalmente via CLI/GitHub integration) ---
# Só precisa se for fazer deploy manual via API
# VERCEL_TOKEN=

# --- APIs do projeto agente-lista-linkedin ---
# SerpApi (descoberta de perfis via Google) — 100 buscas/mês no free tier
# Cadastre em https://serpapi.com e pegue a chave em Dashboard > API Key
SERPAPI_KEY=

# Proxycurl → descontinuado (agora NinjaPear, que não aceita LinkedIn URL).
# v1 do agente ranqueia apenas com título+snippet do SerpApi (sem enrichment).
# Reservado pra v2 futura (ex: Apify, Scrapingdog, ou outro scraper legal):
# PROXYCURL_API_KEY=

# --- Outras integrações (se seu projeto precisar) ---
# OPENAI_API_KEY=
# N8N_WEBHOOK_URL=
# DATABASE_URL=
# GOOGLE_API_KEY=
